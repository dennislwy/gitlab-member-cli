{
	"servers": {
		"gitlab": {
			"command": "npx",
			"args": [
				"-y",
				"@zereight/mcp-gitlab@2.0.25"
			],
			"env": {
				"GITLAB_PERSONAL_ACCESS_TOKEN": "${input:gitlab_token}",
				"GITLAB_API_URL": "${input:gitlab_api_url}",
				"GITLAB_READ_ONLY_MODE": "false",
				"USE_GITLAB_WIKI": "false",
				"USE_MILESTONE": "false",
				"USE_PIPELINE": "false"
			},
			"type": "stdio"
		},
		"context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp",
			"headers": {
				"CONTEXT7_API_KEY": "${input:context7_api_key}"
			}
		}
	},
	"inputs": [
		{
			"id": "gitlab_token",
			"type": "promptString",
			"description": "GitLab Personal Access Token"
		},
		{
			"id": "gitlab_api_url",
			"type": "promptString",
			"description": "GitLab API URL"
		},
		{
			"id": "context7_api_key",
			"type": "promptString",
			"description": "Context7 API Key"
		}
	]
}